# FlowEngine Portal - Docker Environment Template
# Copy to .env:  cp .env.docker .env
# Then edit the values below and run:  docker compose up -d --build
#
# Or use the quick-start script:  ./setup.sh

# ===========================================
# Postgres
# ===========================================
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# ===========================================
# JWT / Supabase Keys
# ===========================================
# All three values below must use the SAME JWT_SECRET.
#
# Generate:
#   JWT_SECRET:        openssl rand -base64 32
#   ANON_KEY / SERVICE_ROLE_KEY: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#     (use your JWT_SECRET and the payloads: {"role":"anon"} / {"role":"service_role"})
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjoyMDAwMDAwMDAwfQ.placeholder
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMDAwMDAwMDB9.placeholder

# ===========================================
# URLs  ← CRITICAL: read carefully
# ===========================================
# SITE_URL = the public URL users open in their browser.
#   - Local:      http://localhost:3000
#   - Production: https://portal.yourdomain.com
#
# ⚠️  Browser Supabase calls are proxied through Next.js (no separate API port needed).
#     NEXT_PUBLIC_SUPABASE_URL is set automatically to SITE_URL — do not change it.
SITE_URL=http://localhost:3000

# ===========================================
# Encryption (for stored API keys / credentials)
# ===========================================
# Required if you store API keys (Stripe, OpenClaw, etc.) via the portal settings UI.
# Generate: openssl rand -hex 32
ENCRYPTION_SECRET=change-me-generate-with-openssl-rand-hex-32

# Kong HTTP port (internal Supabase API gateway — not exposed to browsers)
KONG_HTTP_PORT=8000

# Portal port (direct access, e.g. behind nginx or for local dev)
PORTAL_PORT=3000

# ===========================================
# Domain (Traefik / Coolify only)
# ===========================================
# Set PORTAL_DOMAIN to your public domain to enable Traefik HTTPS routing.
# Leave empty for standalone installs (access via PORTAL_PORT above).
#
# Example: PORTAL_DOMAIN=portal.yourdomain.com
PORTAL_DOMAIN=

# ===========================================
# Auth Settings
# ===========================================
# Auto-confirm email signups — set to false to require email verification (needs SMTP below)
ENABLE_EMAIL_AUTOCONFIRM=true

# Set to true to disable self-registration (invite-only)
DISABLE_SIGNUP=false

# ===========================================
# OPTIONAL - SMTP (for email confirmations + invitations)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com
# SMTP_SENDER_NAME=FlowEngine

# ===========================================
# OPTIONAL - Demo Mode
# ===========================================
# Set to true to make the portal read-only (all write API calls return 403).
# Shows a banner: "This is a live demo — changes are disabled."
# Toggle in Coolify/Docker env vars without rebuilding.
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_DEMO_EMAIL=demo@yourdomain.com   ← pre-created Supabase user
# NEXT_PUBLIC_DEMO_PASSWORD=your-demo-password

# ===========================================
# OPTIONAL - AI Features (Widget Studio AI assistant)
# ===========================================
# Any OpenAI-compatible API works (OpenRouter, local Ollama, etc.)
# Leave unset to disable AI features, or configure via Settings in the portal UI.
# AI_BASE_URL=https://openrouter.ai/api
# AI_API_KEY=sk-or-...
# AI_MODEL=anthropic/claude-sonnet-4-5

# ===========================================
# OPTIONAL - OAuth Providers
# ===========================================
# ENABLE_GOOGLE_AUTH=true
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# ENABLE_GITHUB_AUTH=true
# GITHUB_CLIENT_ID=xxx
# GITHUB_CLIENT_SECRET=xxx
